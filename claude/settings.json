{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Edit",
      "Bash(git status)",
      "Bash(git status *)",
      "Bash(git log)",
      "Bash(git log *)",
      "Bash(git show *)",
      "Bash(git diff)",
      "Bash(git diff *)",
      "Bash(git blame *)",
      "Bash(git shortlog *)",
      "Bash(git worktree *)",
      "Bash(git fetch)",
      "Bash(git fetch *)",
      "Bash(git branch)",
      "Bash(git branch *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git checkout *)",
      "Bash(rg *)",
      "Bash(ls)",
      "Bash(ls *)",
      "Bash(grep *)",
      "Bash(find *)",
      "Bash(fd *)",
      "Bash(sed *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(pwd)",
      "Bash(cd *)",
      "Bash(mkdir *)",
      "Bash(uniq *)",
      "Bash(echo *)",
      "Bash(awk *)",
      "Bash(wc *)",
      "Bash(sort *)",
      "Bash(xargs *)",
      "Bash(bundle exec srb tc)",
      "Bash(bundle exec srb tc *)",
      "Bash(yarn test)",
      "Bash(yarn test *)",
      "Bash(npm test)",
      "Bash(npm test *)",
      "Bash(bin/dev *)",
      "Bash(cargo *)",
      "Bash(crystal *)",
      "Bash(bundle *)",
      "Bash(bun *)",
      "Bash(gh issue view *)",
      "Bash(gh issue list *)",
      "Bash(gh repo view *)",
      "Bash(gh pr view *)",
      "Bash(gh pr create *)",
      "Bash(gh pr list *)",
      "Bash(gh pr diff *)",
      "Bash(gh search *)",
      "Bash(gh release view *)",
      "Bash(gh release list *)",
      "Bash(which *)",
      "Bash(RAILS_ENV=test bin/rails *)",
      "Bash(bin/rails *)",
      "Bash(bundle exec rubocop)",
      "Bash(bundle exec rubocop *)",
      "Bash(bundle exec haml-lint *)",
      "Bash(jq *)",
      "Bash(time *)",
      "Bash(open *)",
      "Bash(touch *)",
      "Bash(diff *)",
      "Bash(printf *)",
      "Bash(stat *)",
      "Bash(file *)",
      "Bash(test *)",
      "Bash(date *)",
      "Bash(env)",
      "Bash(env *)",
      "Bash(true)",
      "Bash(false)",
      "Bash(rm /tmp/agent-seed-*)",
      "Bash(rm /tmp/seed-*)",
      "Bash(git push*)",
      "Bash(* 2>/dev/null)",
      "Bash(* >/dev/null)",
      "Bash(* >/dev/null 2>&1)",
      "Bash(* 2>&1 >/dev/null)",
      "Bash(* > /dev/null)",
      "Bash(* > /dev/null 2>&1)",
      "Bash(fish -c 'agent *)",
      "Bash(fish -c \"agent *)",
      "Bash(fish -c 'type agent*)",
      "Read",
      "WebFetch",
      "WebSearch"
    ],
    "deny": [],
    "defaultMode": "acceptEdits"
  },
  "disabledMcpjsonServers": [
    "chrome-devtools"
  ],
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "PROMPT=$(cat | jq -r '.userPrompt // empty' 2>/dev/null); if echo \"$PROMPT\" | grep -qE '^/[a-z]'; then SKILL=$(echo \"$PROMPT\" | grep -oE '^/[a-z-]+' | sed 's/^\\///'); echo \"$SKILL\" >> /tmp/cc-user-invoked-skill; fi; exit 0"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "INPUT=$(cat); CMD=$(echo \"$INPUT\" | jq -r '.tool_input.command // empty'); if echo \"$CMD\" | grep -qE '(^|[ ;&|])git[[:space:]]+push'; then BR=$(git branch --show-current 2>/dev/null); if [ \"$BR\" = main ] || [ \"$BR\" = master ]; then echo \"BLOCKED: refusing git push from protected branch '$BR'\" >&2; exit 2; fi; fi; exit 0"
          }
        ]
      },
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "INPUT=$(cat); SKILL=$(echo \"$INPUT\" | jq -r '.tool_input.skill // empty'); USER_INVOKED=/tmp/cc-user-invoked-skill; if grep -qF \"$SKILL\" \"$USER_INVOKED\" 2>/dev/null; then sed -i '' \"/$SKILL/d\" \"$USER_INVOKED\"; exit 0; fi; echo \"BLOCKED: Use /$SKILL to invoke explicitly.\" >&2; exit 2"
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.config/claude/hooks/agent-state.sh awaiting"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.config/claude/hooks/agent-state.sh idle"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "ruby-lsp@claude-plugins-official": true,
    "rust-analyzer-lsp@claude-plugins-official": true,
    "lua-lsp@claude-plugins-official": true
  },
  "effortLevel": "xhigh",
  "claudeMdExcludes": [
    "CLAUDE.md",
    ".claude/CLAUDE.md",
    ".claude/rules/**",
    "AGENTS.md"
  ],
  "defaultMode": "acceptEdits",
  "additionalDirectories": [
    "~/Documents/repos",
    "~/.asdf/installs",
    "~/worktrees"
  ],
  "mcpServers": {
    "circleci": {
      "command": "npx",
      "args": [
        "-y",
        "@circleci/mcp-server-circleci@latest"
      ]
    }
  }
}
